#!/usr/bin/env bash
# Idempotent set-up of the local e2e test stack: builds canisters (only when
# source is newer than the wasm), starts the test OpenID providers, icp
# network, dev server, and (re)installs the canisters with the same init args
# the e2e CI job uses. Designed to be re-run on every code change — re-runs
# detect what's already healthy and only do incremental work.
#
# Usage:
#   scripts/dev-e2e-setup              set up; exit 0 when everything is ready
#   scripts/dev-e2e-setup --teardown   stop everything this script started

set -euo pipefail

SCRIPTS_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPTS_DIR/.."
REPO_ROOT="$PWD"

# Match the e2e job in .github/workflows/canister-tests.yml
LAUNCHER_TAG="v12.0.0-2026-04-16-04-20"
OPENID_PORTS=(11105 11106 11107 11108)
DIRECT_OPENID_PORTS=(11105 11106)
# 11108 is an Entra-style provider: pairwise `sub` (per client) + a stable `oid`,
# for the non-`sub` gating tests (see fixtures/sso.ts SSO_ENTRA_DISCOVERY_DOMAIN).
# (127.0.0.1:11107 is the same provider under a distinct host, letting the gating
# tests use a discovery-cache entry the un-gated tests never touch.)
PAIRWISE_OPENID_PORT=11108

STATE_DIR=".icp/cache/dev-e2e"
LAUNCHER_DIR="$STATE_DIR/launcher-$LAUNCHER_TAG"
LOG_DIR="$STATE_DIR/logs"
STATE_FILE="$STATE_DIR/state"
II_ARGS_FILE="$STATE_DIR/ii-init-args.did"
FE_ARGS_FILE="$STATE_DIR/fe-init-args.did"
mkdir -p "$STATE_DIR" "$LOG_DIR"

log() { printf '\033[1;36m>>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*" >&2; }
die() { printf '\033[1;31mxx\033[0m %s\n' "$*" >&2; exit 1; }

# State is shell-sourceable: NETWORK_STARTED_BY_US, DEV_SERVER_PID, OPENID_PIDS, II_CANISTER_ID.
load_state() {
  NETWORK_STARTED_BY_US=0
  DEV_SERVER_PID=""
  OPENID_PIDS=""
  II_CANISTER_ID=""
  # Use `if` rather than `[[ ]] && source` — under `set -e`, the latter exits
  # the script when the state file doesn't exist (cold first run).
  if [[ -f "$STATE_FILE" ]]; then
    # shellcheck source=/dev/null
    source "$STATE_FILE"
  fi
}

save_state() {
  cat > "$STATE_FILE" <<EOF
NETWORK_STARTED_BY_US=$NETWORK_STARTED_BY_US
DEV_SERVER_PID="$DEV_SERVER_PID"
OPENID_PIDS="$OPENID_PIDS"
II_CANISTER_ID="$II_CANISTER_ID"
EOF
}

# Linux's kill -0 also succeeds against zombies; check /proc/<pid>/status when
# available to distinguish them from real running processes.
pid_alive() {
  local p=$1
  [[ -n "$p" ]] || return 1
  kill -0 "$p" 2>/dev/null || return 1
  [[ -r /proc/$p/status ]] || return 0
  [[ "$(awk '/^State:/{print $2}' /proc/$p/status 2>/dev/null)" != "Z" ]]
}

# Walk the full process tree before signalling anyone: if we killed parents
# while descending, npm's own signal handler would tear down its `sh` child
# before we could enumerate the vite grandchild — leaving vite orphaned to
# init and still holding the port. Collect all descendants first, then
# signal everything at once.
collect_descendants() {
  local pid=$1
  printf '%s\n' "$pid"
  local children
  children=$(pgrep -P "$pid" 2>/dev/null || true)
  for child in $children; do
    collect_descendants "$child"
  done
}

kill_tree() {
  local pid=$1
  [[ -z "$pid" ]] && return
  local all_pids
  all_pids=$(collect_descendants "$pid")
  while IFS= read -r p; do
    [[ -n "$p" ]] && kill -TERM "$p" 2>/dev/null || true
  done <<<"$all_pids"
  # Stragglers that ignored SIGTERM (npm sometimes does) — force them.
  sleep 0.3
  while IFS= read -r p; do
    [[ -n "$p" ]] && kill -KILL "$p" 2>/dev/null || true
  done <<<"$all_pids"
}

ensure_prereqs() {
  # pgrep (procps-ng) backs collect_descendants — without it teardown can't
  # walk the process tree and stray vite/esbuild grandchildren leak.
  for cmd in node npm cargo curl tar pgrep; do
    command -v "$cmd" >/dev/null || die "Missing required tool: $cmd"
  done

  local want_node="v$(cat .node-version)"
  if [[ "$(node --version)" != "$want_node" ]]; then
    warn "Node version mismatch: have $(node --version), repo pins $want_node"
  fi

  if ! command -v ic-wasm >/dev/null; then
    die "Missing ic-wasm. Install with: cargo install ic-wasm --version 0.8.5"
  fi

  if ! command -v icp >/dev/null; then
    local v
    v=$(tr -d '[:space:]' < .icp-cli-version)
    log "Installing @icp-sdk/icp-cli@$v globally"
    npm install -g "@icp-sdk/icp-cli@$v"
  fi
}

# v13 launchers ship a pocket-ic that rejects canister-sig delegations whose
# subnet cert omits subnet_type — which breaks the OpenID/consent e2e tests.
# Match the workflow's v12 pin until dfinity/ic#10226 lands in a launcher release.
ensure_launcher() {
  local bin="$LAUNCHER_DIR/icp-cli-network-launcher"
  if [[ -x "$bin" ]]; then
    export ICP_CLI_NETWORK_LAUNCHER_PATH="$bin"
    return
  fi

  local os arch
  case "$(uname -s)" in
    Linux) os=linux ;;
    Darwin) os=darwin ;;
    *) die "Unsupported OS: $(uname -s)" ;;
  esac
  case "$(uname -m)" in
    x86_64) arch=x86_64 ;;
    arm64|aarch64) arch=arm64 ;;
    *) die "Unsupported arch: $(uname -m)" ;;
  esac

  local url="https://github.com/dfinity/icp-cli-network-launcher/releases/download/$LAUNCHER_TAG/icp-cli-network-launcher-$arch-$os-$LAUNCHER_TAG.tar.gz"
  log "Downloading pinned network launcher ($arch-$os, $LAUNCHER_TAG)"
  mkdir -p "$LAUNCHER_DIR"
  # Tarball wraps binaries in a top-level dir matching the archive name —
  # strip it so the binary lands directly at $LAUNCHER_DIR/icp-cli-network-launcher.
  curl --proto '=https' --tlsv1.2 -fsSL "$url" | tar xz -C "$LAUNCHER_DIR" --strip-components=1
  [[ -x "$bin" ]] || die "Launcher binary not found at $bin after extract"
  export ICP_CLI_NETWORK_LAUNCHER_PATH="$bin"
}

ensure_node_deps() {
  if [[ ! -d node_modules ]]; then
    log "npm ci"
    npm ci --no-audit --no-fund
  fi
  if [[ ! -d src/test_openid_provider/node_modules ]]; then
    log "npm ci (test_openid_provider)"
    npm ci --prefix ./src/test_openid_provider --no-audit --no-fund
  fi
  if [[ ! -d "${PLAYWRIGHT_BROWSERS_PATH:-$HOME/.cache/ms-playwright}" ]]; then
    log "Installing Playwright Chromium"
    npx playwright install chromium
  fi

  # icp.yaml references .icp/cache/init-args/internet_identity_frontend.did
  # and refuses to start the network if the file is missing — re-render every
  # run so a manually-cleaned .icp/ doesn't break the next startup. Content
  # doesn't matter here because we override init args via --args-file at install.
  ./scripts/render-local-init-args >/dev/null
}

# Returns 0 if any source file in $1 is newer than $2 (or $2 doesn't exist).
# Used to skip the cargo build + vite when nothing in the canister has changed
# since the wasm was last produced — the slow path here is `npm run build`,
# which always runs unconditionally inside `./scripts/build --frontend`.
#
# Mirrors the watcher's filter: ignore-list (editor noise, hidden files) rather
# than an allow-list, so asset changes (.svg/.png/.woff2/...) inside src/frontend
# correctly invalidate the FE wasm.
needs_rebuild() {
  local src_dir=$1 wasm=$2
  [[ -f "$wasm" ]] || return 0
  find "$src_dir" -type f -newer "$wasm" \
    ! -name '.*' ! -name '*~' \
    ! -name '*.swp' ! -name '*.swo' ! -name '*.swx' ! -name '*.tmp' \
    -print -quit 2>/dev/null | grep -q . && return 0 || return 1
}

build_canisters() {
  REBUILT_II=0
  REBUILT_FE=0
  if needs_rebuild src/internet_identity internet_identity.wasm.gz; then
    log "Building internet_identity (cargo)"
    II_FETCH_ROOT_KEY=1 ./scripts/build --internet-identity
    REBUILT_II=1
  else
    log "internet_identity.wasm.gz up to date, skipping build"
  fi
  # FE canister bundles src/frontend assets via `npm run build`, so a UI
  # change should trigger an FE-canister rebuild even though the canister's
  # own Rust code didn't change. Watch both trees.
  if needs_rebuild src/internet_identity_frontend internet_identity_frontend.wasm.gz \
     || needs_rebuild src/frontend internet_identity_frontend.wasm.gz; then
    log "Building internet_identity_frontend (cargo + npm)"
    II_FETCH_ROOT_KEY=1 ./scripts/build --frontend
    REBUILT_FE=1
  else
    log "internet_identity_frontend.wasm.gz up to date, skipping build"
  fi
  if [[ ! -f demos/test-app/test_app.wasm ]]; then
    log "Building demos/test-app"
    ( cd demos/test-app && ./build.sh )
  fi
}

start_openid_providers() {
  local need_start=0
  for port in "${OPENID_PORTS[@]}"; do
    curl -fsS "http://localhost:$port/jwks" >/dev/null 2>&1 || { need_start=1; break; }
  done
  if [[ "$need_start" == 0 ]]; then
    log "OpenID providers already responding on ${OPENID_PORTS[*]}"
    return
  fi

  # Tear down stale provider PIDs from a previous run before respawning so
  # we don't end up with duplicates on the same port.
  if [[ -n "$OPENID_PIDS" ]]; then
    for pid in $OPENID_PIDS; do kill_tree "$pid"; done
  fi

  log "Starting test OpenID providers on: ${OPENID_PORTS[*]}"
  local new_pids=()
  for port in "${OPENID_PORTS[@]}"; do
    if [[ "$port" == "$PAIRWISE_OPENID_PORT" ]]; then
      # Entra-style: pairwise `sub` + a stable `oid`, named for the consent/dialog
      # copy. Pairwise needs single-host redirect_uris (or a sector_identifier_uri);
      # the e2e II origin is https://id.ai, so restrict to that one callback.
      OIDC_SUBJECT_TYPE=pairwise OIDC_SSO_NAME="Entra SSO" \
        OIDC_REDIRECT_URIS="https://id.ai/callback" \
        npm start --silent --prefix ./src/test_openid_provider -- "$port" \
        > "$LOG_DIR/openid-$port.log" 2>&1 &
    else
      npm start --silent --prefix ./src/test_openid_provider -- "$port" \
        > "$LOG_DIR/openid-$port.log" 2>&1 &
    fi
    new_pids+=("$!")
  done
  OPENID_PIDS="${new_pids[*]}"

  for port in "${OPENID_PORTS[@]}"; do
    local tries=0
    until curl -fsS "http://localhost:$port/jwks" >/dev/null 2>&1; do
      tries=$((tries+1))
      [[ $tries -gt 30 ]] && die "OpenID provider on $port did not become ready"
      sleep 0.5
    done
  done
}

# icp tracks running networks in two places that both need to be clean:
#   ~/.cache/icp-cli/port-descriptors/<port>.{json,lock}  — global per-port
#   .icp/cache/networks/local/{descriptor.json,lock}      — project-local
# If the launcher dies without `icp network stop` (kill -9, crash, container
# exit) these survive pointing at a dead PID and `icp network start` errors
# with "already running" or "port in use" until they're removed.
purge_stale_port_descriptors() {
  local f owner pid
  shopt -s nullglob
  for f in "$HOME"/.cache/icp-cli/port-descriptors/*.json; do
    owner=$(grep -o '"project-dir": *"[^"]*"' "$f" 2>/dev/null | head -1 | sed 's/.*"\([^"]*\)"$/\1/')
    pid=$(grep -o '"pid": *[0-9]*' "$f" 2>/dev/null | head -1 | awk '{print $2}')
    [[ "$owner" == "$REPO_ROOT" ]] || continue
    if ! pid_alive "$pid"; then
      log "Removing stale global port descriptor: $(basename "$f")"
      rm -f "$f" "${f%.json}.lock"
    fi
  done
  shopt -u nullglob

  local local_desc=".icp/cache/networks/local/descriptor.json"
  if [[ -f "$local_desc" ]]; then
    pid=$(grep -o '"pid": *[0-9]*' "$local_desc" 2>/dev/null | head -1 | awk '{print $2}')
    if ! pid_alive "$pid"; then
      log "Removing stale project network descriptor"
      rm -f "$local_desc" ".icp/cache/networks/local/lock"
    fi
  fi
}

start_network() {
  purge_stale_port_descriptors
  if icp network status >/dev/null 2>&1; then
    log "icp network already running, reusing"
  else
    log "Starting icp network (daemon)"
    icp network start -d
    NETWORK_STARTED_BY_US=1
  fi
}

write_install_args() {
  local svg='<svg viewBox=\"0 0 24 24\"><path d=\"m14 2.8-2.6 1.8v16.6l2.6-1.4zm-3.3 5.4C1.9 9 2 14.7 2 14.7c0 5.6 8.7 6.5 8.7 6.5v-1.9c-6.3-1-5.5-4.5-5.5-4.5.3-4 5.5-4.3 5.5-4.3Zm4 0v2.1s1.6 0 3 1.2l-1.5.6 5.8 1.4V9l-2 1.1s-1.7-1.7-5.3-1.9z\" style=\"fill: currentColor;\"></path></svg>'
  local configs=()
  for port in "${DIRECT_OPENID_PORTS[@]}"; do
    configs+=("record { name = \"Test OpenID $port\"; logo = \"$svg\"; issuer = \"http://localhost:$port\"; client_id = \"internet_identity\"; jwks_uri = \"http://localhost:$port/jwks\"; auth_uri = \"http://localhost:$port/auth\"; auth_scope = vec { \"openid\"; \"profile\"; \"email\" }; fedcm_uri = opt \"\"; email_verification = opt variant { Google }; }")
  done
  local openid_configs dnssec_config
  openid_configs="$(IFS='; '; echo "${configs[*]}")"
  dnssec_config="$(node src/frontend/tests/e2e-playwright/utils/renderDnssecTestAnchor.mjs)"

  cat > "$II_ARGS_FILE" <<EOF
(opt record { captcha_config = opt record { max_unsolved_captchas= 50:nat64; captcha_trigger = variant {Static = variant { CaptchaDisabled }}}; related_origins = opt vec { "https://id.ai"; "https://identity.ic0.app"; "https://identity.internetcomputer.org" }; new_flow_origins = opt vec { "https://id.ai" }; openid_configs = opt vec { $openid_configs }; sso_allow_insecure_discovery = opt true; enable_dnssec_email_recovery = opt true; dnssec_config = $dnssec_config })
EOF

  # FE args depend on the II canister ID, which we only know after create_canisters.
  # Render them after that step from the same source of truth.
}

write_fe_install_args() {
  cat > "$FE_ARGS_FILE" <<EOF
(record { backend_canister_id = principal "$II_CANISTER_ID"; backend_origin = "https://backend.id.ai"; related_origins = opt vec { "https://id.ai"; "https://identity.ic0.app"; "https://identity.internetcomputer.org" }; fetch_root_key = opt true; dev_csp = opt true })
EOF
}

create_canisters() {
  for name in internet_identity internet_identity_frontend test_app; do
    if icp canister status "$name" --id-only >/dev/null 2>&1; then
      :
    else
      icp canister create "$name" >/dev/null
      log "Created canister $name"
    fi
  done
  II_CANISTER_ID="$(icp canister status internet_identity --id-only)"
}

# Per-canister install: skip if the wasm wasn't rebuilt this run AND a module
# is already installed. Detect "module installed?" via `--json`, which always
# emits a `"module_hash"` field — `null` when empty, a hex string when set.
# Without --json icp can throw a CanisterError when invoked against a fresh
# canister, so JSON is the only stable path here.
module_installed() {
  local name=$1
  icp canister status "$name" --json 2>/dev/null \
    | grep -q '"module_hash":"[0-9a-f]'
}

install_canisters() {
  local name wasm args_file rebuilt
  for entry in \
      "internet_identity|internet_identity.wasm.gz|$II_ARGS_FILE|$REBUILT_II" \
      "internet_identity_frontend|internet_identity_frontend.wasm.gz|$FE_ARGS_FILE|$REBUILT_FE" \
      "test_app|demos/test-app/test_app.wasm||0"; do
    IFS='|' read -r name wasm args_file rebuilt <<<"$entry"
    if module_installed "$name" && [[ "$rebuilt" != 1 ]]; then
      log "Canister $name already installed and up to date"
      continue
    fi
    local mode
    if module_installed "$name"; then mode=upgrade; else mode=auto; fi
    log "Installing $name (--mode $mode)"
    if [[ -n "$args_file" ]]; then
      icp canister install "$name" -y --mode "$mode" --wasm "$wasm" --args-file "$args_file"
    else
      icp canister install "$name" -y --mode "$mode" --wasm "$wasm"
    fi
  done
}

# The dev server returns HTTP 500 on a bare GET (no Host header matches the
# configured related_origins) — so use TCP-level liveness rather than `curl -f`,
# which would treat the 500 as failure and start a duplicate. Use `localhost`
# rather than 127.0.0.1: vite binds to ::1 (IPv6 loopback) by default and the
# 127.0.0.1 probe gets ECONNREFUSED even though the server is up.
port_listening() {
  bash -c "exec 3<>/dev/tcp/localhost/$1" 2>/dev/null
}

start_dev_server() {
  if [[ -n "$DEV_SERVER_PID" ]] && pid_alive "$DEV_SERVER_PID" && port_listening 5173; then
    log "Dev server already running on https://localhost:5173 (pid $DEV_SERVER_PID)"
    return
  fi

  if port_listening 5173; then
    warn "Port 5173 is in use by an untracked process; refusing to start a duplicate"
    warn "Run: scripts/dev-e2e-setup --teardown   then re-run setup"
    die "5173 unavailable"
  fi

  log "Starting dev server"
  # Truncate the log so the readiness grep only matches the new process —
  # otherwise a stale "ready in" from a previous run produces a false positive.
  : > "$LOG_DIR/dev-server.log"
  SEPARATE_FRONTEND_CANISTER=1 TLS_DEV_SERVER=1 NO_HOT_RELOAD=1 \
    npm run dev > "$LOG_DIR/dev-server.log" 2>&1 &
  DEV_SERVER_PID=$!
  local tries=0
  until grep -q "ready in" "$LOG_DIR/dev-server.log" 2>/dev/null; do
    tries=$((tries+1))
    [[ $tries -gt 60 ]] && die "Dev server did not become ready (see $LOG_DIR/dev-server.log)"
    sleep 0.5
  done
  log "Dev server ready on https://localhost:5173"
}

do_setup() {
  load_state
  ensure_prereqs
  ensure_launcher
  ensure_node_deps
  build_canisters
  start_openid_providers
  start_network
  write_install_args
  create_canisters
  write_fe_install_args
  install_canisters
  start_dev_server
  save_state
  log "Setup complete. Dev server: https://localhost:5173"
  log "II canister id: $II_CANISTER_ID"
  log "Run tests: npx playwright test --project=desktop [--grep <name>]"
}

do_teardown() {
  load_state
  log "Tearing down dev-e2e state"
  if [[ -n "$DEV_SERVER_PID" ]]; then kill_tree "$DEV_SERVER_PID"; fi
  if [[ -n "$OPENID_PIDS" ]]; then
    for pid in $OPENID_PIDS; do kill_tree "$pid"; done
  fi
  if [[ "$NETWORK_STARTED_BY_US" == 1 ]]; then
    icp network stop 2>/dev/null || true
    # `icp network stop` leaves the global port descriptor behind, which
    # makes `icp network status` report stale info until the next setup
    # purges it. Clean it up for symmetry.
    rm -f "$HOME"/.cache/icp-cli/port-descriptors/8000.{json,lock}
  fi
  rm -f "$STATE_FILE" "$II_ARGS_FILE" "$FE_ARGS_FILE"
  log "Teardown complete"
}

case "${1:-}" in
  --teardown) do_teardown ;;
  -h|--help)
    cat <<EOF
Usage:
  scripts/dev-e2e-setup              set up the e2e stack; exits when ready
  scripts/dev-e2e-setup --teardown   stop everything this script started

Re-runnable: subsequent invocations detect what's already healthy (network,
OpenID providers, dev server) and only redo the work that's needed.

  - Canisters rebuild only when their source is newer than the wasm.
  - Rebuilt canisters get redeployed with --mode upgrade.
  - Network/OpenID/dev-server processes are reused if responding.

State is kept under .icp/cache/dev-e2e/ (gitignored via .icp/).
EOF
    ;;
  "") do_setup ;;
  *) die "Unknown argument: $1 (see --help)" ;;
esac
