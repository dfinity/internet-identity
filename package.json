{
  "name": "@dfinity/internet-identity",
  "version": "0.1.0",
  "type": "module",
  "description": "",
  "keywords": [],
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "scripts": {
    "dev": "II_FETCH_ROOT_KEY=1 II_DUMMY_CAPTCHA=1 vite",
    "host": "II_FETCH_ROOT_KEY=1 II_DUMMY_CAPTCHA=1 vite --host",
    "build": "npm run extract && tsc --noEmit && vite build",
    "preview": "vite preview",
    "postinstall": "scripts/render-local-init-args",
    "prepare": "svelte-kit sync || echo ''",
    "check": "tsc --project ./tsconfig.all.json --noEmit && svelte-check check",
    "watch": "npm run check -- --watch",
    "opts": "TS_NODE_PROJECT=tsconfig.base.json NODE_OPTIONS='--loader ts-node/esm --experimental-specifier-resolution=node' \"$@\"",
    "generate": "npm run generate:types && npm run generate:js && npm run generate:types-frontend && npm run generate:js-frontend && npm run generate:types-issuer && npm run generate:js-issuer",
    "generate:types": "didc bind ./src/internet_identity/internet_identity.did -t ts | ./scripts/rewrite-dfinity-imports > src/frontend/src/lib/generated/internet_identity_types.d.ts",
    "generate:js": "didc bind ./src/internet_identity/internet_identity.did -t js | ./scripts/rewrite-dfinity-imports > src/frontend/src/lib/generated/internet_identity_idl.js",
    "generate:types-frontend": "didc bind ./src/internet_identity_frontend/internet_identity_frontend.did -t ts | ./scripts/rewrite-dfinity-imports > src/frontend/src/lib/generated/internet_identity_frontend_types.d.ts",
    "generate:js-frontend": "didc bind ./src/internet_identity_frontend/internet_identity_frontend.did -t js | ./scripts/rewrite-dfinity-imports > src/frontend/src/lib/generated/internet_identity_frontend_idl.js",
    "generate:types-issuer": "didc bind ./demos/vc_issuer/vc_demo_issuer.did -t ts | ./scripts/rewrite-dfinity-imports > src/vc-api/src/generated/vc_issuer_types.ts",
    "generate:js-issuer": "didc bind ./demos/vc_issuer/vc_demo_issuer.did -t js | ./scripts/rewrite-dfinity-imports > src/frontend/src/lib/generated/vc_issuer_idl.js",
    "screenshots": "npm run opts -- ./src/frontend/screenshots.ts",
    "test": "vitest --config ./vitest.config.ts",
    "test:e2e": "VITEST_MAX_THREADS=1 vitest --mode e2e --config ./vitest.config.ts",
    "test:e2e-desktop": "SCREEN=desktop npm run test:e2e",
    "test:e2e-mobile": "SCREEN=mobile npm run test:e2e",
    "test:e2e-playwright": "npx playwright test",
    "lint": "npm run lint:eslint && npm run lint:lit",
    "lint:eslint": "eslint --max-warnings 0 --cache --cache-location node_modules/.cache/eslint 'src/frontend/**/*.{ts,svelte}'",
    "lint:lit": "lit-analyzer -- --rules.no-incompatible-type-binding off --rules.no-invalid-directive-binding off --rules.no-noncallable-event-binding off ./src/frontend",
    "format": "prettier --write src/frontend src/vc-api src/sig-verifier-js src/vite-plugins tsconfig.json tsconfig.all.json eslint.config.js vite.config.ts vitest.config.ts demos",
    "format-check": "prettier --check src/frontend src/vc-api src/sig-verifier-js src/vite-plugins tsconfig.json tsconfig.all.json eslint.config.js vite.config.ts vitest.config.ts demos",
    "extract": "lingui extract --clean",
    "compile": "echo \"Does nothing, compilation is handled by the Vite plugin\""
  },
  "devDependencies": {
    "@dfinity/internet-identity-vite-plugins": "*",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@lingui/cli": "^5.9.5",
    "@lingui/vite-plugin": "^5.9.5",
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "*",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitest/browser": "^4.1.9",
    "@zag-js/svelte": "^1.41.2",
    "@zag-js/toast": "^1.41.2",
    "devtools-protocol": "^0.0.1653615",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "estree-walker": "^3.0.3",
    "fake-indexeddb": "^4.0.2",
    "globals": "^15.14.0",
    "jsdom": "^28.1.0",
    "lines-and-columns": "^2.0.4",
    "lit-analyzer": "^2.0.2",
    "magic-string": "^0.30.21",
    "prettier": "3.9.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.3.6",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@dfinity/internet-identity-vc-api": "*",
    "@icp-sdk/core": "^5.0.0",
    "@lingui/core": "^5.9.5",
    "@lucide/svelte": "^0.577.0",
    "@noble/hashes": "^2.2.0",
    "bip39": "^3.0.4",
    "borc": "^2.1.1",
    "buffer": "^6.0.3",
    "dompurify": "^3.4.11",
    "idb-keyval": "^6.2.6",
    "lit-html": "^3.3.3",
    "marked": "^11.0.0",
    "plausible-tracker": "0.3.9",
    "qr-creator": "^1.0.0",
    "stream-browserify": "^3.0.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "npm": ">=11.0.0 <12.0.0",
    "node": ">=24.0.0 <25.0.0"
  },
  "workspaces": [
    "src/vc-api",
    "demos/vc_issuer",
    "src/vite-plugins",
    "src/sig-verifier-js"
  ]
}
