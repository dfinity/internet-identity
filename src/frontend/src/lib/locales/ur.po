msgstr "سوئچ کریں"

msgid "Switch access method"
msgstr "رسائی کا طریقہ تبدیل کریں"

msgid "Switch identity"
msgstr "شناخت تبدیل کریں"

msgid "Switch method"
msgstr "طریقہ تبدیل کریں"

msgid "Switch to another method before removing"
msgstr "ہٹانے سے پہلے کسی اور طریقے پر سوئچ کریں"

msgid "Switch to another method before unlinking"
msgstr "ان لنک کرنے سے پہلے کسی اور طریقے پر سوئچ کریں"

msgid "Switching..."
msgstr "سوئچ ہو رہا ہے..."

msgid "Tap on the <0>address bar</0> and <1>open in browser</1>."
msgstr "<0>ایڈریس بار</0> پر ٹیپ کریں اور <1>براؤزر میں کھولیں</1>۔"

msgid "Tap on the highlighted <0>back</0> button."
msgstr "نمایاں کیے گئے <0>واپس</0> بٹن پر ٹیپ کریں۔"

msgid "Test passkey support"
msgstr "پاس کی سپورٹ کو ٹیسٹ کریں"

msgid "Test passkey support and view authenticator details"
msgstr "پاس کی سپورٹ کو ٹیسٹ کریں اور آتھنٹیکیٹر کی تفصیلات دیکھیں"

msgid "Test sign-in"
msgstr "سائن اِن کو ٹیسٹ کریں"

msgid "That identity doesn't match"
msgstr "وہ شناخت مطابقت نہیں کھاتی"

msgid "The <0>existing device</0> is preparing to continue."
msgstr "<0>موجودہ ڈیوائس</0> جاری رکھنے کی تیاری کر رہی ہے۔"

msgid "The <0>new device</0> is preparing to continue."
msgstr "<0>نئی ڈیوائس</0> جاری رکھنے کی تیاری کر رہی ہے۔"

msgid "The CLI gets full access to your account in this app."
msgstr "CLI اس ایپ میں آپ کے اکاؤنٹ تک مکمل رسائی حاصل کرتا ہے۔"

msgid "The CLI gets its own account, separate from your other apps."
msgstr "CLI کو اپنا ایک الگ اکاؤنٹ ملتا ہے، جو آپ کی دوسری ایپس سے الگ ہوتا ہے۔"

msgid "The CLI sign-in couldn't be completed. Check the CLI for details."
msgstr "CLI سائن اِن مکمل نہیں ہو سکا۔ تفصیلات کے لیے CLI چیک کریں۔"

msgid "The DNSSEC zone must use a current algorithm — RSA/SHA-256, RSA/SHA-512, ECDSA P-256, or Ed25519. The deprecated SHA-1 algorithms aren't supported."
msgstr "DNSSEC زون کو ایک موجودہ الگورتھم استعمال کرنا ضروری ہے — RSA/SHA-256، RSA/SHA-512، ECDSA P-256، یا Ed25519۔ فرسودہ SHA-1 الگورتھم سپورٹ نہیں ہیں۔"

msgid "The email needs to come from the address above directly. Aliases and forwarders won't work."
msgstr "ای میل براہ راست اوپر دیے گئے پتے سے آنی چاہیے۔ عرفی نام اور فارورڈرز کام نہیں کریں گے۔"

msgid "The integration with Google, Microsoft and Apple uses a standard authentication protocol called OpenID. This is the same protocol that other applications use to log in with Google."
msgstr "Google، Microsoft اور Apple کے ساتھ انٹیگریشن ایک معیاری تصدیقی پروٹوکول استعمال کرتی ہے جسے OpenID کہا جاتا ہے۔ یہی وہی پروٹوکول ہے جسے دیگر ایپلیکیشنز Google کے ساتھ لاگ اِن کے لیے استعمال کرتی ہیں۔"

msgid "The most reliable backup. Stored entirely by you, on paper. It does not depend on any account, service, or provider, and only you can use, lose, or replace it."
msgstr "سب سے قابلِ اعتماد بیک اپ۔ مکمل طور پر آپ کے ذریعے، کاغذ پر محفوظ۔ یہ کسی بھی اکاؤنٹ، سروس، یا فراہم کنندہ پر منحصر نہیں، اور صرف آپ ہی اسے استعمال، کھو، یا تبدیل کر سکتے ہیں۔"

msgid "The phrase was entered correctly but belongs to a product other than Internet Identity."
msgstr "فریز درست درج کی گئی ہے، لیکن یہ Internet Identity کے بجائے کسی اور پروڈکٹ سے متعلق ہے۔"

msgid "There was an issue connecting with the application. Try a different browser; if the issue persists, contact the developer."
msgstr "ایپلیکیشن کے ساتھ منسلک ہونے میں مسئلہ پیش آیا۔ دوسرا براؤزر آزمائیں؛ اگر مسئلہ برقرار رہے تو ڈویلپر سے رابطہ کریں۔"

msgid "This {providerName} account is already connected to an Internet Identity."
msgstr "یہ {providerName} اکاؤنٹ پہلے سے ایک Internet Identity سے منسلک ہے۔"

msgid "This {providerName} account isn't connected to an Internet Identity yet."
msgstr "یہ {providerName} اکاؤنٹ ابھی تک کسی Internet Identity سے منسلک نہیں ہے۔"

msgid "This account is already attached to your identity. Your active access method will be switched to it."
msgstr "یہ اکاؤنٹ پہلے سے آپ کی شناخت سے منسلک ہے۔ آپ کا فعال رسائی طریقہ اس پر تبدیل کر دیا جائے گا۔"

msgid "This app has moved to the new Internet Identity"
msgstr "یہ ایپ نئی Internet Identity پر منتقل ہو گئی ہے"

msgid "This browser is not supported."
msgstr "یہ براؤزر معاون نہیں ہے۔"

msgid "This identity has already been upgraded to the new experience."
msgstr "یہ شناخت پہلے ہی نئے تجربے پر اپ گریڈ ہو چکی ہے۔"

msgid "This is now the default method used to authenticate moving forward on this device."
msgstr "یہ اب اس آلے پر آگے تصدیق کے لیے استعمال ہونے والا ڈیفالٹ طریقہ ہے۔"

msgid "This is the access method you're currently signed in with."
msgstr "یہ وہ رسائی کا طریقہ ہے جس سے آپ فی الحال سائن اِن ہیں۔"

msgid "This is the recovery method you're currently signed in with."
msgstr "یہ وہ ریکوری طریقہ ہے جس سے آپ فی الحال سائن اِن ہیں۔"

msgid "This legacy passkey is no longer usable and should be removed."
msgstr "یہ پرانی پاس کی اب قابل استعمال نہیں ہے اور اسے ہٹا دینا چاہیے"

msgid "This may take a few seconds"
msgstr "اس میں کچھ سیکنڈ لگ سکتے ہیں"

msgid "This passkey is no longer associated with any identity."
msgstr "یہ پاس کی اب کسی شناخت سے منسلک نہیں ہے۔"

msgid "This passkey seems to have issues, please share the export with support."
msgstr "یہ پاس کی مسائل کا شکار لگتی ہے۔ برائے کرم ایکسپورٹ سپورٹ کے ساتھ شیئر کریں۔"

msgid "This SSO is already linked to your identity."
msgstr "یہ SSO پہلے ہی آپ کی شناخت سے منسلک ہے۔"

msgid "This usually takes under 30 seconds."
msgstr "یہ عام طور پر ۳۰ سیکنڈ سے کم وقت لیتا ہے۔"

msgid "This will become the default method used to authenticate on this device moving forward."
msgstr "یہ اس آلے پر آگے تصدیق کے لیے استعمال ہونے والا ڈیفالٹ طریقہ بن جائے گا۔"

msgid "To"
msgstr "بہ"

msgid "To accept email from a domain we either need DNSSEC at its apex (so we can cryptographically validate the DKIM key your provider uses) or for the domain to be on our list of known mailbox providers."
msgstr "کسی ڈومین سے ای میل قبول کرنے کے لیے ہمیں یا تو اس کی بنیاد پر DNSSEC کی ضرورت ہے (تاکہ ہم آپ کے فراہم کنندہ کے استعمال کردہ DKIM کلید کو کرپٹوگرافک طریقے سے تصدیق کر سکیں) یا ڈومین کا ہمارے معروف میل باکس فراہم کنندگان کی فہرست میں ہونا ضروری ہے۔"

msgid "To confirm it's you, enter below code on your <0>existing device</0>."
msgstr "یہ تصدیق کرنے کے لیے کہ یہ آپ ہیں، اپنی <0>موجودہ ڈیوائس</0> پر نیچے دیا گیا کوڈ درج کریں۔"

msgid "to continue to {dappName}"
msgstr "{dappName} پر جاری رکھنے کے لیے"

msgid "to continue with <0>{application}</0>"
msgstr "<0>{application}</0> کے ساتھ جاری رکھنے کے لیے"

msgid "to continue with this app"
msgstr "اس ایپ کے ساتھ جاری رکھنے کے لیے"

msgid "To continue, create a passkey to secure your identity and simplify future sign-ins."
msgstr "جاری رکھنے کے لیے، اپنی شناخت کو محفوظ بنانے اور مستقبل کے سائن اِن کو آسان بنانے کے لیے ایک پاس کی بنائیں۔"

msgid "To continue:"
msgstr "جاری رکھنے کے لیے:"

msgid "To finish setting up your passkey, follow the instructions shown on your <0>new device</0>."
msgstr "اپنی پاس کی سیٹ اپ مکمل کرنے کے لیے، اپنی <0>نئی ڈیوائس</0> پر دکھائی گئی ہدایات پر عمل کریں۔"

msgid "Try a different address"
msgstr "کوئی اور پتہ آزمائیں"

msgid "Try again"
msgstr "دوبارہ کوشش کریں"

msgid "Type each word in the correct order:"
msgstr "ہر لفظ درست ترتیب میں درج کریں:"

msgid "Type the characters exactly as shown below"
msgstr "حروف کو بالکل ویسے ہی ٹائپ کریں جیسے نیچے دکھائے گئے ہیں"

msgid "Type the email address you registered as your recovery method. We'll ask you to send a signed email from this inbox to confirm."
msgstr "وہ ای میل پتہ درج کریں جسے آپ نے اپنے ریکوری طریقے کے طور پر رجسٹر کیا ہے۔ ہم آپ سے تصدیق کے لیے اس ان باکس سے ایک دستخط شدہ ای میل بھیجنے کا کہیں گے۔"

msgid "Type the email address you want to use to recover this Internet Identity. We'll ask you to send a signed email from this inbox to confirm."
msgstr "وہ ای میل پتہ درج کریں جو آپ اس Internet Identity کو بازیافت کرنے کے لیے استعمال کرنا چاہتے ہیں۔ ہم آپ سے تصدیق کے لیے اس ان باکس سے ایک دستخط شدہ ای میل بھیجنے کا کہیں گے۔"

msgid "Type your 24 recovery words."
msgstr "اپنے ۲۴ ریکوری الفاظ درج کریں۔"

msgid "Unable to complete setup"
msgstr "سیٹ اپ مکمل نہیں ہو سکا"

msgid "Unable to connect"
msgstr "رابطہ قائم نہیں ہو سکا"

msgid "Understanding Internet Identity"
msgstr "Internet Identity کو سمجھیں"

msgid "Undo"
msgstr "واپس کریں"

msgid "Unknown"
msgstr "نامعلوم"

msgid "Unlike many Web3 auth systems that require manual signing for every action, Internet Identity creates authenticated sessions per application. This delivers both security and convenience (no repeated signing) while still giving each session its own identity."
msgstr "بہت سے Web3 تصدیقی نظاموں کے برعکس جن میں ہر عمل کے لیے دستی دستخط کی ضرورت ہوتی ہے، Internet Identity ہر ایپلیکیشن کے لیے تصدیق شدہ سیشن بناتی ہے۔ یہ سیکیورٹی اور سہولت دونوں فراہم کرتی ہے (بار بار دستخط کی ضرورت نہیں) جبکہ ہر سیشن کو اپنی شناخت بھی دیتی ہے۔"

msgid "Unlink"
msgstr "ان لنک کریں"

msgid "Unlink and sign out"
msgstr "ان لنک کریں اور سائن آؤٹ کریں"

msgid "Unlinking and signing out..."
msgstr "ان لنک ہو رہا ہے اور سائن آؤٹ ہو رہا ہے..."

msgid "Unlinking..."
msgstr "ان لنک ہو رہا ہے..."

msgid "Unlock and reset"
msgstr "ان لاک کریں اور ری سیٹ کریں"

msgid "Unlock to continue"
msgstr "جاری رکھنے کے لیے ان لاک کریں"

msgid "Unsupported browser"
msgstr "غیر معاون براؤزر"

msgid "Unverified origin"
msgstr "غیر تصدیق شدہ اوریجن"

msgid "Update recovery email"
msgstr "ریکوری ای میل اپ ڈیٹ کریں"

msgid "Upgrade"
msgstr "اپ گریڈ کریں"

msgid "Upgrade again"
msgstr "دوبارہ اپ گریڈ کریں"

msgid "Upgrade completed successfully"
msgstr "اپ گریڈ کامیابی سے مکمل ہو گیا"

msgid "Upgrade identity"
msgstr "شناخت اپ گریڈ کریں"

msgid "Upgrade your existing identity to the new experience in a two steps."
msgstr "دو مراحل میں اپنی موجودہ شناخت کو نئے تجربے پر اپ گریڈ کریں۔"

msgid "Upgrade your identity"
msgstr "اپنی شناخت اپ گریڈ کریں"

msgid "Upgrading identity..."
msgstr "شناخت اپ گریڈ کی جا رہی ہے..."

msgid "Use a device that already holds your identity to scan or open the URL. This will link your identity to this device."
msgstr "یو آر ایل کو سکین کرنے یا کھولنے کے لیے ایسا آلہ استعمال کریں جس میں پہلے سے آپ کی شناخت موجود ہو۔ اس سے آپ کی شناخت اس آلے کے ساتھ منسلک ہو جائے گی۔"

msgid "Use a passkey, Face ID, or a popular provider"
msgstr "پاس کی، Face ID، یا ایک مقبول فراہم کنندہ استعمال کریں"

msgid "Use existing identity"
msgstr "موجودہ شناخت استعمال کریں"

msgid "Use these to regain access to your identity if you ever lose it."
msgstr "اگر آپ کبھی اپنی شناخت کھو دیں تو اسے دوبارہ حاصل کرنے کے لیے انہیں استعمال کریں۔"

msgid "Verification failed"
msgstr "تصدیق ناکام ہو گئی"

msgid "Verify"
msgstr "تصدیق کریں"

msgid "Verify recovery phrase"
msgstr "ریکوری فریز کی تصدیق کریں"

msgid "Verify recovery to remove"
msgstr "ہٹانے کے لیے ریکوری کی تصدیق کریں"

msgid "Verify you are human"
msgstr "تصدیق کریں کہ آپ انسان ہیں"

msgid "Verify your email"
msgstr "اپنی ای میل کی تصدیق کریں"

msgid "Verify your recovery phrase"
msgstr "اپنے ریکوری فریز کی تصدیق کریں"

msgid "Verifying..."
msgstr "تصدیق ہو رہی ہے..."

msgid "Verifying…"
msgstr "تصدیق ہو رہی ہے…"

msgid "View your last used identities"
msgstr "اپنی آخری بار استعمال شدہ شناختیں دیکھیں"

msgid "Waiting for your existing device"
msgstr "آپ کے موجودہ آلے کا انتظار ہے"

msgid "Waiting for your new device"
msgstr "آپ کے نئے آلے کا انتظار ہے"

msgid "Waiting to receive…"
msgstr "موصول ہونے کا انتظار ہے…"

msgid "Want to create a new identity?"
msgstr "کیا آپ ایک نئی شناخت بنانا چاہتے ہیں؟"

msgid "We can't verify mail from <0>{domain}</0> yet. Try a different address. Gmail, iCloud, Outlook, Fastmail, and Proton all work."
msgstr "ہم ابھی <0>{domain}</0> سے میل کی تصدیق نہیں کر سکتے۔ کوئی اور پتہ آزمائیں۔ Gmail، iCloud، Outlook، Fastmail، اور Proton سب کام کرتے ہیں۔"

msgid "We didn't recognize that activation code."
msgstr "درج کیا گیا ایکٹیویشن کوڈ درست یا قابلِ شناخت نہیں ہے"

msgid "Welcome, <0>{name}</0>."
msgstr "خوش آمدید، <0>{name}</0>۔"

msgid "What are passkeys?"
msgstr "پاس کیز کیا ہیں؟"

msgid "What is Internet Identity?"
msgstr "Internet Identity کیا ہے؟"

msgid "What makes Internet Identity privacy-preserving?"
msgstr "Internet Identity رازداری کیسے برقرار رکھتی ہے؟"

msgid "What makes Internet Identity secure & easy to use?"
msgstr "Internet Identity کو محفوظ اور آسان استعمال کیا بناتا ہے؟"

msgid "What's new in Internet Identity 2.0?"
msgstr "Internet Identity 2.0 میں نیا کیا ہے؟"

msgid "What's your name?"
msgstr "آپ کا نام کیا ہے؟"

msgid "When you create a passkey, your device makes two matching keys. One stays safely on your device, and the other goes to the app or service. They work together to confirm it's you (without ever sharing your personal info or a password)."
msgstr "جب آپ پاس کی بناتے ہیں، تو آپ کا آلہ دو مطابقت رکھنے والی کیز بناتا ہے۔ ایک آپ کے آلے پر محفوظ رہتی ہے، اور دوسری ایپ یا سروس کو جاتی ہے۔ یہ مل کر تصدیق کرتی ہیں کہ یہ آپ ہی ہیں (بغیر کبھی آپ کی ذاتی معلومات یا پاس ورڈ شیئر کیے)۔"

msgid "Why am I seeing this?"
msgstr "میں یہ کیوں دیکھ رہا/رہی ہوں؟"

msgid "Why isn't this supported?"
msgstr "یہ کیوں معاون نہیں ہے؟"

msgid "With passkeys, you can now use your fingerprint, face, or screen lock to quickly and securely confirm it’s really you."
msgstr "پاس کیز کے ساتھ، اب آپ اپنی فنگرپرنٹ، چہرہ، یا سکرین لاک کا استعمال کر سکتے ہیں تاکہ جلدی اور محفوظ طریقے سے تصدیق کر سکیں کہ یہ واقعی آپ ہی ہیں۔"

msgid "with your identity in this app"
msgstr "اس ایپ میں آپ کی شناخت کے ساتھ"

msgid "with your Internet Identity"
msgstr "اپنی Internet Identity کے ذریعے"

msgid "Word {position}"
msgstr "لفظ {position}"

msgid "Write down all 24 words correctly and keep them offline. Do not store them in the cloud or on devices."
msgstr "تمام 24 الفاظ درست طریقے سے لکھ لیں اور انہیں آف لائن رکھیں۔ انہیں کلاؤڈ یا آلات پر محفوظ نہ کریں۔"

msgid "Write down your recovery phrase in order and verify it afterwards. Store it safely and do not share it. Losing it means you will lose access."
msgstr "اپنا ریکوری فریز ترتیب سے لکھ لیں اور اس کے بعد اس کی تصدیق کریں۔ اسے محفوظ رکھیں اور شیئر نہ کریں۔ اسے کھونے کا مطلب ہے کہ آپ اپنی رسائی کھو دیں گے۔"

msgid "Wrong domain was set. Please try again."
msgstr "غلط ڈومین سیٹ کیا گیا تھا۔ براہ کرم دوبارہ کوشش کریں۔"

msgid "You <0>cannot</0> rename this once it is set."
msgstr "ایک بار سیٹ ہو جانے کے بعد آپ اس کا <0>نام تبدیل نہیں کر سکتے</0>۔"

msgid "You already have a {name} account linked"
msgstr "آپ کا پہلے ہی ایک {name} اکاؤنٹ منسلک ہے"

msgid "You are about to re-authenticate yourself with another access method."
msgstr "آپ ایک اور رسائی کے طریقے سے اپنی تصدیق دوبارہ کرنے والے ہیں۔"

msgid "You are about to remove your last remaining access method. Your recovery method will become your sole way of regaining access to this identity."
msgstr "آپ اپنا آخری باقی رسائی کا طریقہ ہٹانے والے ہیں۔ آپ کا ریکوری طریقہ اس شناخت تک دوبارہ رسائی حاصل کرنے کا آپ کا واحد ذریعہ بن جائے گا۔"

msgid "You are about to unlink your last remaining access method. Your recovery method will become your sole way of regaining access to this identity."
msgstr "آپ اپنا آخری باقی رسائی کا طریقہ ان لنک کرنے والے ہیں۔ آپ کا ریکوری طریقہ اس شناخت تک دوبارہ رسائی حاصل کرنے کا آپ کا واحد ذریعہ بن جائے گا۔"

msgid "You are upgrading ID <0>{identityNumber}</0>"
msgstr "آپ ID <0>{identityNumber}</0> کو اپ گریڈ کر رہے ہیں"

msgid "You can add it back anytime by signing in with the same {provider} account."
msgstr "آپ اسی {provider} اکاؤنٹ سے سائن اِن کر کے اسے کسی بھی وقت واپس شامل کر سکتے ہیں۔"

msgid "You can add it back anytime by signing in with the same passkey."
msgstr "آپ اسی پاس کی سے سائن اِن کر کے اسے کسی بھی وقت واپس شامل کر سکتے ہیں۔"

msgid "You can close this window."
msgstr "آپ یہ ونڈو بند کر سکتے ہیں۔"

msgid "You can continue with <0>Use existing Passkey</0> in the login process."
msgstr "آپ سائن اِن کے عمل میں <0>موجودہ پاس کی استعمال کریں</0> کے ساتھ جاری رکھ سکتے ہیں۔"

msgid "You can either sign out and keep your identity saved for a faster login next time, or remove it entirely from this device."
msgstr "آپ سائن آؤٹ کر کے اپنی شناخت کو اگلی بار تیز لاگ اِن کے لیے محفوظ رکھ سکتے ہیں، یا اسے اس آلے سے مکمل طور پر ہٹا سکتے ہیں۔"

msgid "You can manage your access methods on this page."
msgstr "آپ اس صفحے پر اپنے رسائی کے طریقوں کا انتظام کر سکتے ہیں۔"

msgid "You can reset your recovery phrase at any time. This keeps your identity secure if it is ever exposed."
msgstr "آپ کسی بھی وقت اپنا ریکوری فریز ری سیٹ کر سکتے ہیں۔ اگر یہ کبھی منظر عام پر آ جائے تو اس طرح آپ کی شناخت محفوظ رہتی ہے۔"

msgid "You can use it now to recover, but verify you've saved it correctly so you can rely on it later."
msgstr "آپ اسے ابھی بازیافت کے لیے استعمال کر سکتے ہیں، لیکن تصدیق کریں کہ آپ نے اسے درست طریقے سے محفوظ کیا ہے تاکہ آپ بعد میں اس پر انحصار کر سکیں۔"

msgid "You have reached the maximum number of passkeys"
msgstr "آپ پاس کیز کی زیادہ سے زیادہ تعداد تک پہنچ چکے ہیں"

msgid "You may close this page."
msgstr "آپ یہ صفحہ بند کر سکتے ہیں۔"

msgid "You no longer need to remember your identity number and can use your fingerprint, face or screen lock instead."
msgstr "اب آپ کو اپنا شناختی نمبر یاد رکھنے کی ضرورت نہیں ہے اور اس کے بجائے آپ فنگرپرنٹ، چہرہ یا سکرین لاک استعمال کر سکتے ہیں۔"

msgid "You signed up before with a different access method."
msgstr "آپ نے پہلے ایک مختلف رسائی طریقے سے سائن اَپ کیا تھا۔"

msgid "You unlinked this {providerName} account from your identity."
msgstr "آپ نے یہ {providerName} اکاؤنٹ اپنی شناخت سے ان لنک کر دیا۔"

msgid "You're about to see your recovery phrase, which Internet Identity doesn't store and thus can't be retrieved if lost, so keep it safe offline."
msgstr "آپ اب اپنی ریکوری فریز دیکھنے والے ہیں۔ Internet Identity اسے محفوظ نہیں رکھتی، اس لیے اگر یہ گم ہو جائے تو دوبارہ حاصل نہیں کی جا سکتی۔ لہٰذا اسے آف لائن محفوظ رکھیں"

msgid "You're about to sign in on a <0>new device</0>."
msgstr "آپ ایک <0>نئی ڈیوائس</0> پر سائن اِن کرنے والے ہیں۔"

msgid "You're about to sign in."
msgstr "آپ سائن اِن کرنے والے ہیں۔"

msgid "You're about to unlink your {providerName} account."
msgstr "آپ اپنا {providerName} اکاؤنٹ ان لنک کرنے والے ہیں۔"

msgid "You're all set. Your identity has been created."
msgstr "سب تیار ہے۔ آپ کی شناخت بن گئی ہے۔"

msgid "You're all set. Your passkey has been registered."
msgstr "سب تیار ہے۔ آپ کی پاس کی رجسٹر ہو گئی ہے۔"

msgid "You're signed in"
msgstr "آپ سائن اِن ہیں"

msgid "You're signing in as <0>{name}</0>."
msgstr "آپ بطور <0>{name}</0> سائن اِن کر رہے ہیں۔"

msgid "You've never used this {providerName} account with Internet Identity."
msgstr "آپ نے یہ {providerName} اکاؤنٹ کبھی بھی Internet Identity کے ساتھ استعمال نہیں کیا۔"

msgid "Your passkeys and recovery phrase are unaffected. You can add a recovery email again at any time."
msgstr "آپ کی Passkeys اور ریکوری فریز متاثر نہیں ہوتیں۔ آپ کسی بھی وقت دوبارہ ریکوری ای میل شامل کر سکتے ہیں۔"

msgid "Your provider's DKIM key is verified by quorum consensus across independent DNS resolvers."
msgstr "آپ کے فراہم کنندہ کی DKIM کلید آزاد DNS ریزولورز میں اکثریتی اتفاق رائے کے ذریعے تصدیق شدہ ہے۔"

msgid "Your provider's DKIM key is verified end-to-end via DNSSEC. No trusted intermediaries."
msgstr "آپ کے فراہم کنندہ کی DKIM کلید DNSSEC کے ذریعے سرے سے سرے تک تصدیق شدہ ہے۔ کوئی قابلِ اعتماد درمیانی نہیں۔"

msgid "Your recovery email has been detached from this identity."
msgstr "آپ کی ریکوری ای میل اس شناخت سے الگ کر دی گئی ہے۔"

msgid "Your recovery phrase gives full control over your identity. Never share it and only use it on the official website."
msgstr "آپ کا ریکوری فریز آپ کی شناخت پر مکمل کنٹرول دیتا ہے۔ اسے کبھی شیئر نہ کریں اور صرف آفیشل ویب سائٹ پر استعمال کریں۔"

msgid "Your recovery phrase is now active and can be reset anytime."
msgstr "آپ کا ریکوری فریز اب فعال ہے اور اسے کسی بھی وقت ری سیٹ کیا جا سکتا ہے۔"
