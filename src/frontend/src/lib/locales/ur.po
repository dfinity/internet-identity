msgstr "{providerName} نام:"

msgid "<0>{address}</0> will no longer be able to sign in to your identity."
msgstr "<0>{address}</0> اب آپ کی شناخت میں سائن اِن کرنے کے قابل نہیں رہے گا۔"

msgid "<0>Completely redesigned interface:</0> We've given Internet Identity a fresh, modern look and feel. The new design is intuitive and easier to navigate, ensuring a smoother user journey."
msgstr "<0>مکمل طور پر نئے سرے سے ڈیزائن کردہ انٹرفیس:</0> ہم نے Internet Identity کو ایک تازہ، جدید شکل اور احساس دیا ہے۔ نیا ڈیزائن بدیہی اور نیویگیٹ کرنے میں آسان ہے، جو صارف کے سفر کو زیادہ ہموار بناتا ہے۔"

msgid "<0>Google, Apple and Microsoft integrations:</0> While passkeys are becoming more mature, they are not yet mainstream for everyone. We've observed a 50% drop-off rate in our registration flow, indicating a need for alternative authentication methods. To make Internet Identity accessible to an even wider audience, we've integrated with Google, Apple and Microsoft as alternative authentication options."
msgstr "<0>Google، Apple اور Microsoft کے انضمام:</0> اگرچہ Passkeys زیادہ پختہ ہوتی جا رہی ہیں، لیکن یہ ابھی سب کے لیے عام نہیں ہوئیں۔ ہم نے اپنے رجسٹریشن کے عمل میں ۵۰٪ ڈراپ آف کی شرح دیکھی ہے، جو متبادل تصدیقی طریقوں کی ضرورت کی نشاندہی کرتی ہے۔ Internet Identity کو ایک وسیع تر سامعین کے لیے قابلِ رسائی بنانے کے لیے، ہم نے متبادل تصدیقی آپشنز کے طور پر Google، Apple اور Microsoft کے ساتھ انضمام کیا ہے۔"

msgid "<0>Learn more</0> about passkeys"
msgstr "<0>مزید جانیں</0> پاس کیز کے بارے میں"

msgid "<0>Never</0> enter a code from another source."
msgstr "<0>کبھی بھی</0> کسی دوسرے ذریعے سے کوڈ درج نہ کریں۔"

msgid "<0>No more identity numbers:</0> As explained above, discoverable passkeys mean you no longer need to remember or store an identity number. Logging in is now simpler and more streamlined."
msgstr "<0>شناختی نمبر کی ضرورت نہیں:</0> جیسا کہ اوپر بیان کیا گیا ہے، قابلِ دریافت Passkeys کا مطلب ہے کہ آپ کو اب شناختی نمبر یاد رکھنے یا محفوظ کرنے کی ضرورت نہیں۔ لاگ اِن کرنا اب آسان اور زیادہ سلیس ہو گیا ہے۔"

msgid "<0>Seamless passkey integration:</0> We continue to embrace passkeys as the future of secure authentication. Internet Identity 2.0 leverages the latest passkey standards for enhanced security and ease of use."
msgstr "<0>ہموار Passkey انضمام:</0> ہم محفوظ تصدیق کے مستقبل کے طور پر Passkeys کو اپنانا جاری رکھتے ہیں۔ Internet Identity 2.0 بہتر سیکیورٹی اور آسانی کے لیے جدید ترین Passkey معیارات کا استعمال کرتی ہے۔"

msgid "A 24-word phrase you write down and keep offline."
msgstr "۲۴ الفاظ پر مشتمل فریز جسے آپ لکھ کر آف لائن رکھتے ہیں۔"

