msgstr "{domainInput} کی SSO نے \"{0}\" واپس کیا: {1}"

msgid "{domainInput}'s SSO returned error \"{0}\"."
msgstr "{domainInput} کی SSO نے ایرر \"{0}\" واپس کیا۔"

