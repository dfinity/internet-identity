msgstr "Viac informácií o viacerých účtoch"

msgid "More options"
msgstr "Ďalšie možnosti"

msgid "Multiple accounts"
msgstr "Viacero účtov"

msgid "My {application} account"
msgstr "Môj účet {application}"

msgid "My account"
msgstr "Môj účet"

msgid "My identity"
msgstr "Moja identita"

msgid "n/a"
