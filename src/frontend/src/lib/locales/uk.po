msgstr "Збережено та доступно лише на пристрої {0}, на якому його було створено."

msgid "Stored in your {0} account and synced across your {1} devices."
msgstr "Збережено у вашому обліковому записі {0} та синхронізовано на ваших {1} пристроях."

msgid "Stored in your {0} account and synced across your devices."
msgstr "Збережено у вашому обліковому записі {0} та синхронізовано на ваших пристроях."

msgid "Stored securely on your device, in your password manager, or on a security key."
msgstr "Збережено безпечно на вашому пристрої, у вашому менеджері паролів або на ключі безпеки."

